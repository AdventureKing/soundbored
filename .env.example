# Discord Bot Configuration
DISCORD_TOKEN=your_discord_token_here
DISCORD_REQUIRED_GUILD_ID=123456789012345678
DISCORD_ROLE_GUILD_ID=123456789012345678
DISCORD_UPLOAD_ROLE_IDS=111111111111111111,222222222222222222
DISCORD_PLAY_ROLE_IDS=111111111111111111,444444444444444444
DISCORD_SETTINGS_ADMIN_USER_ID=333333333333333333
DISCORD_CLIENT_ID=your_client_id_here
DISCORD_CLIENT_SECRET=your_client_secret_here

# Application Configuration
PHX_HOST=localhost
SCHEME=http
SECRET_KEY_BASE=generate_with_mix_phx_gen_secret_or_openssl_rand
# Voice channel behaviour (enable explicitly when desired)
AUTO_JOIN=false

# Native DAVE audio backend (enabled by default; set false only for troubleshooting)
EDA_DAVE=true
# Probe URL-backed clips for duration metadata during create
PROBE_REMOTE_DURATIONS=true
# Run duration backfill on container boot (set false to skip)
BACKFILL_DURATIONS_ON_BOOT=true
# Also probe URL-backed sounds during backfill (can be slower)
BACKFILL_DURATIONS_INCLUDE_URL=false

# Basic Auth - Comment these out to disable basic auth
BASIC_AUTH_USERNAME=admin
BASIC_AUTH_PASSWORD=admin

# Docker Configuration
COMPOSE_PROJECT_NAME=soundbored
