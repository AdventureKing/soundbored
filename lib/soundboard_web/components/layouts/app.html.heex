<.live_component
  module={SoundboardWeb.Components.Layouts.Navbar}
  id="navbar"
  current_user={@current_user}
  current_path={@current_path}
  presences={@presences}
  cooldown_end_ms={assigns[:cooldown_end_ms]}
  cooldown_remaining_ms={assigns[:cooldown_remaining_ms]}
/>

<main class="desktop-nav-main min-h-screen bg-[#16181e] text-[#e2e0d8] pt-14 transition-[padding-left] duration-200 lg:pt-0">
  <.flash_group flash={@flash} />
  {@inner_content}
</main>
